# Copy this to .env and fill in your credentials

# Gmail — EMAIL_PASSWORD should be an App Password (not your login password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_SENDER=you@gmail.com
EMAIL_RECEIVER=you@gmail.com
EMAIL_PASSWORD="xxxx xxxx xxxx xxxx"

# Flight data backend: fast-flights (default, no key needed) or serpapi
# Set FLIGHT_API=serpapi and provide your key from https://serpapi.com
FLIGHT_API=fast-flights
SERPAPI_KEY=your_serpapi_key_here
